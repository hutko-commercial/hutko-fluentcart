#: includes/class-hutko-fc-api.php
msgid "Hutko API Return code is %s. Please try again later."
msgstr "API Hutko повернув код %s. Спробуйте пізніше."

#: includes/class-hutko-fc-api.php
msgid "Unknown Hutko API answer."
msgstr "Невідома відповідь API Hutko."

#: includes/class-hutko-fc-api.php
msgid "Empty request body."
msgstr "Порожнє тіло запиту."

#: includes/class-hutko-fc-api.php
msgid "Merchant data is incorrect. Expected: %1$s, Received: %2$s"
msgstr "Невірні дані мерчанта. Очікувалось: %1$s, отримано: %2$s"

#: includes/class-hutko-fc-api.php
msgid "Signature is not valid"
msgstr "Невірний підпис"

#: includes/class-hutko-fc-gateway.php
msgid "Cards, Apple Pay, Google Pay via Hutko"
msgstr "Картки, Apple Pay, Google Pay через Hutko"

#: includes/class-hutko-fc-gateway.php
msgid "Redirecting to Hutko..."
msgstr "Перенаправлення на Hutko..."

#: includes/class-hutko-fc-gateway.php
msgid "Order #%s"
msgstr "Замовлення №%s"

#: includes/class-hutko-fc-gateway.php
msgid "Order info retrieved!"
msgstr "Інформацію про замовлення отримано!"

#: includes/class-hutko-fc-gateway.php
msgid "No Hutko order ID stored on this transaction."
msgstr "У цій транзакції немає збереженого ID замовлення Hutko."

#: includes/class-hutko-fc-gateway.php
msgid "Refund amount is required."
msgstr "Необхідно вказати суму повернення."

#: includes/class-hutko-fc-gateway.php
msgid "Refund failed. Hutko status: %s"
msgstr "Повернення не вдалося. Статус Hutko: %s"

#: includes/class-hutko-fc-gateway.php
msgid "Enable Hutko"
msgstr "Увімкнути Hutko"

#: includes/class-hutko-fc-gateway.php
msgid "Test mode"
msgstr "Тестовий режим"

#: includes/class-hutko-fc-gateway.php
msgid "Use Hutko test merchant credentials."
msgstr "Використовувати тестові облікові дані мерчанта Hutko."

#: includes/class-hutko-fc-gateway.php
msgid "Merchant ID"
msgstr "ID мерчанта"

#: includes/class-hutko-fc-gateway.php
msgid "Given to merchant by Hutko."
msgstr "Надається мерчанту Hutko."

#: includes/class-hutko-fc-gateway.php
msgid "Secret Key"
msgstr "Секретний ключ"

#: includes/class-hutko-fc-gateway.php
msgid "Checkout mode"
msgstr "Режим оплати"

#: includes/class-hutko-fc-gateway.php
msgid "Hosted (redirect)"
msgstr "На стороні Hutko (перенаправлення)"

#: includes/class-hutko-fc-gateway.php
msgid "Embedded (on-site widget)"
msgstr "Вбудований (віджет на сайті)"

#: includes/class-hutko-fc-gateway.php
msgid "Choose between redirecting to Hutko or embedding its widget on your site."
msgstr "Оберіть: перенаправлення на Hutko або вбудовування віджету на вашому сайті."

#: includes/class-hutko-fc-gateway.php
msgid "Enable recurring / subscription support"
msgstr "Увімкнути рекурентні платежі / підписки"

#: includes/class-hutko-fc-gateway.php
msgid "Request a rectoken during payment so admins or the auto-renewal cron can re-charge."
msgstr "Запитувати rectoken під час оплати, щоб адміністратори або cron автопродовжень могли повторно списувати кошти."

#: includes/class-hutko-fc-gateway.php
msgid "Callback URL"
msgstr "URL зворотного виклику"

#: includes/class-hutko-fc-gateway.php
msgid "The server-callback URL is sent automatically with every payment request — you do not need to configure anything in the Hutko merchant portal."
msgstr "URL зворотного виклику автоматично передається з кожним запитом на оплату — налаштовувати щось у порталі мерчанта Hutko не потрібно."

#: includes/class-hutko-fc-gateway.php
msgid "Shown here for reference / as a fallback if you want to hardcode it in Hutko:"
msgstr "Показано для довідки / як резервне значення, якщо ви хочете вказати його в Hutko:"

#: includes/class-hutko-fc-gateway.php
msgid "Test mode enabled."
msgstr "Тестовий режим увімкнено."

#: includes/class-hutko-fc-gateway.php
msgid "Merchant ID and Secret Key are required."
msgstr "ID мерчанта та секретний ключ обов'язкові."

#: includes/class-hutko-fc-gateway.php
msgid "Merchant ID must be numeric."
msgstr "ID мерчанта повинен бути числовим."

#: includes/class-hutko-fc-gateway.php
msgid "Hutko settings validated."
msgstr "Налаштування Hutko перевірено."

#: includes/class-hutko-fc-gateway.php
msgid "Missing transaction reference."
msgstr "Відсутнє посилання на транзакцію."

#: includes/class-hutko-fc-gateway.php
msgid "Transaction not found."
msgstr "Транзакцію не знайдено."

#: includes/class-hutko-fc-gateway.php
msgid "Hutko checkout token is missing."
msgstr "Токен оплати Hutko відсутній."

#: includes/class-hutko-fc-gateway.php
msgid "Complete payment"
msgstr "Завершити оплату"

#: includes/class-hutko-fc-gateway.php
msgid "Renewal charge for subscription #%d"
msgstr "Продовження підписки №%d"

#: includes/class-hutko-fc-gateway.php
msgid "Permission denied."
msgstr "Доступ заборонено."

#: includes/class-hutko-fc-gateway.php
msgid "Invalid order or amount."
msgstr "Невірне замовлення або сума."

#: includes/class-hutko-fc-gateway.php
msgid "Order not found."
msgstr "Замовлення не знайдено."

#: includes/class-hutko-fc-gateway.php
msgid "No rectoken available for this order."
msgstr "Для цього замовлення немає збереженого rectoken."

#: includes/class-hutko-fc-gateway.php
msgid "Manual charge for order #%d"
msgstr "Ручне списання для замовлення №%d"

#: includes/class-hutko-fc-gateway.php
msgid "Charge successful: %1$s %2$s. Hutko ID: %3$s"
msgstr "Списання успішне: %1$s %2$s. ID Hutko: %3$s"

#: includes/class-hutko-fc-gateway.php
msgid "Manual charge failed. Status: %s"
msgstr "Ручне списання не вдалося. Статус: %s"

#: hutko-fluentcart-payment-gateway.php
msgid "Settings"
msgstr "Налаштування"

#: hutko-fluentcart-payment-gateway.php
msgid "The minimum PHP version required for Hutko FluentCart Payment Gateway is %1$s. You are running %2$s."
msgstr "Мінімальна версія PHP для Hutko FluentCart Payment Gateway — %1$s. У вас встановлено %2$s."

#: hutko-fluentcart-payment-gateway.php
msgid "Hutko payment for FluentCart requires the FluentCart plugin to be installed and active."
msgstr "Для роботи Hutko payment for FluentCart потрібен встановлений та активний плагін FluentCart."
